# ── Copy this file to .env and fill in your values ──────────────────────────

# Flask
SECRET_KEY=change-this-to-a-long-random-string-in-production
FLASK_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=smart_drive

# Session cookies
# IMPORTANT: Keep this False for local development (HTTP).
# Set to True only when running on HTTPS in production.
SESSION_COOKIE_SECURE=False

# File uploads (leave blank to use default: app/static/uploads/vehicles)
# UPLOAD_FOLDER=

# Email (optional - app works without this)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=SMART DRIVE <noreply@smartdrive.com>

# Admin account (created automatically on first run)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@smartdrive.com
ADMIN_PASSWORD=Admin@SecurePass1!
